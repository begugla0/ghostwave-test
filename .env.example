# GhostWave Panel — переменные окружения
# Скопируйте в .env и заполните значения

# ─── База данных ───────────────────────────────
DB_PASSWORD=your_strong_db_password_here

# ─── Безопасность (генерируем: python -c "import secrets; print(secrets.token_hex(32))") ───
JWT_SECRET=generate_32_byte_hex_here
SECRET_KEY=generate_32_byte_hex_here

# ─── NODE_API_KEY (должен совпадать с .env.node на каждой ноде) ───
NODE_API_KEY=generate_32_byte_hex_here

# ─── Администратор панели ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_admin_password

# ─── Telegram бот ───
# Получить токен: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# Ваш Telegram ID (получить: @userinfobot)
TELEGRAM_ADMIN_IDS=[123456789]

# ─── Subscription URL ──────────────────────────
# Домен панели (без слеша в конце)
SUB_BASE_URL=https://panel.example.com

# ─── Redis ─────────────────────────────────────
REDIS_PASSWORD=ghostwave
